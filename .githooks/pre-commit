#!/bin/sh
# Pre-commit: тесты + авто-включение PDF в коммит

# Проверяем, нужно ли обновить PDF
REGEN=0
if git diff --cached --name-only | grep -qE 'src/js/content\.js|generate-cv\.js'; then
  REGEN=1
fi

# Тесты (пропускаем генерацию PDF если контент не менялся)
echo "Running tests..."
if [ "$REGEN" -eq 1 ]; then
  node test.js
else
  SKIP_PDF_GEN=1 node test.js
fi

if [ $? -ne 0 ]; then
  echo "Tests failed — commit aborted."
  exit 1
fi

# Добавляем PDF в коммит
if [ "$REGEN" -eq 1 ]; then
  echo "Adding regenerated PDF to commit..."
  git add assets/Solovev_Maksim_CV.pdf
fi
