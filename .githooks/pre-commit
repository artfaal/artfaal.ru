#!/bin/sh
# Pre-commit: тесты + авто-включение PDF в коммит

# Проверяем, нужно ли обновить PDF
REGEN=0
if git diff --cached --name-only | grep -qE 'src/js/content\.js|generate-cv\.js'; then
  REGEN=1
fi

# Тесты (пропускаем генерацию PDF если контент не менялся)
echo "Running tests..."
if [ "$REGEN" -eq 1 ]; then
  node test.js
else
  SKIP_PDF_GEN=1 node test.js
fi

if [ $? -ne 0 ]; then
  echo "Tests failed — commit aborted."
  exit 1
fi

# Обновляем lastmod в sitemap.xml
TODAY=$(date +%Y-%m-%d)
sed -i '' "s|<lastmod>[^<]*</lastmod>|<lastmod>${TODAY}</lastmod>|g" sitemap.xml
git add sitemap.xml

# Cache-busting: обновляем ?v=<hash> для CSS/JS в HTML
for f in src/styles/base.css src/styles/layout.css src/styles/components.css \
         src/js/utils.js src/js/content.js src/js/icons.js src/js/shared.js \
         src/js/page-personal.js src/js/page-cv.js; do
  hash=$(md5 -q "$f" | cut -c1-8)
  base=$(basename "$f")
  for html in index.html cv/index.html; do
    sed -i '' "s|${base}\(\?v=[a-f0-9]*\)\{0,1\}\"|${base}?v=${hash}\"|g" "$html"
  done
done
git add index.html cv/index.html

# Генерируем и добавляем оба PDF
if [ "$REGEN" -eq 1 ]; then
  echo "Regenerating PDFs (ru + en)..."
  node generate-cv.js
  node generate-cv.js --en
  git add assets/Solovev_Maksim_CV.pdf assets/Solovev_Maksim_CV_en.pdf
fi
