#!/bin/sh
# Pre-commit: тесты + авто-включение PDF в коммит

# Проверяем, нужно ли обновить PDF
REGEN=0
if git diff --cached --name-only | grep -qE 'src/js/content\.js|generate-cv\.js'; then
  REGEN=1
fi

# Тесты (пропускаем генерацию PDF если контент не менялся)
echo "Running tests..."
if [ "$REGEN" -eq 1 ]; then
  node test.js
else
  SKIP_PDF_GEN=1 node test.js
fi

if [ $? -ne 0 ]; then
  echo "Tests failed — commit aborted."
  exit 1
fi

# Обновляем lastmod в sitemap.xml
TODAY=$(date +%Y-%m-%d)
sed -i '' "s|<lastmod>[^<]*</lastmod>|<lastmod>${TODAY}</lastmod>|g" sitemap.xml
git add sitemap.xml

# Генерируем и добавляем оба PDF
if [ "$REGEN" -eq 1 ]; then
  echo "Regenerating PDFs (ru + en)..."
  node generate-cv.js
  node generate-cv.js --en
  git add assets/Solovev_Maksim_CV.pdf assets/Solovev_Maksim_CV_en.pdf
fi
